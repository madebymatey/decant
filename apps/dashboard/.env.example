# ── Database (Neon Postgres) ────────────────────────────────────────────────
# Pooled connection string from the Neon dashboard.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Generate: `openssl rand -base64 32`
AUTH_SECRET=""
# Google OAuth client (https://console.cloud.google.com → Credentials → OAuth client ID)
# Authorized redirect URI: https://decant.matey.co/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Canonical site URL (set on Vercel to the production domain).
AUTH_URL="https://decant.matey.co"

# ── Access control ──────────────────────────────────────────────────────────
# The authoritative admin. This email can always sign in and is force-promoted
# to admin on login, even before any domain is allowlisted. Set this first.
BOOTSTRAP_ADMIN_EMAIL="eugene@matey.co"

# ── Secrets encryption ──────────────────────────────────────────────────────
# 32-byte key (64 hex chars) used to encrypt per-project credentials at rest.
# Generate: `openssl rand -hex 32`
SECRETS_ENCRYPTION_KEY=""

# ── Cron ────────────────────────────────────────────────────────────────────
# Vercel sends this automatically as `Authorization: Bearer <CRON_SECRET>` to
# /api/cron/tick. Generate: `openssl rand -hex 32`
CRON_SECRET=""

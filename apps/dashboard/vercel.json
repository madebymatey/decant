{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm exec turbo run build --filter=dashboard...",
  "crons": [
    {
      "path": "/api/cron/tick",
      "schedule": "0 6 * * *"
    }
  ]
}

# =========================================================
# Framer access control (middleware <-> Framer code component)
# =========================================================
# HMAC secret used to sign short-lived, origin-bound tokens. Required.
TOKEN_SECRET=
# Token lifetime in seconds.
TOKEN_TTL_SECONDS=300
# CSV of exact allowed browser origins, e.g.
# https://www.yourwinery.com,https://yourwinery.com
ALLOWED_ORIGINS=
# Allow Framer editor/preview origins (*.framercanvas.com, *.framer.app) while
# designing. Set to false in production once you've locked ALLOWED_ORIGINS.
ALLOW_FRAMER_EDITOR_ORIGINS=true
# Optional shared secret for the CMS sync feed (/api/feed/products). Set it here
# and configure the same value in your sync tool (FramerSync).
FEED_KEY=

# =========================================================
# WithWine platform — catalog read path (SERVER-SIDE ONLY)
# =========================================================
# WithWine WineryBrandId (sent as the `id` query param).
PLATFORM_STORE_ID=
# WithWine clientId credential — the token used in `Authorization: clientid <token>`.
# Server-side only; NEVER expose to the browser.
PLATFORM_API_KEY=
# Base host. Optional — defaults to https://secure.withwine.com. Override for staging.
PLATFORM_API_URL=
# Optional CDN base for relative product image paths (coverPhotoPath).
PLATFORM_ASSET_URL=
PLATFORM_CURRENCY=USD
PLATFORM_LOCALE=en-US

# =========================================================
# WithWine SDK auth (add when wiring login/session)
# See pages/api/withwine/README.md. The SDK also reads withwine.config.json.
# =========================================================
# WW_CLIENT_SECRET=
# WW_ENV=production
